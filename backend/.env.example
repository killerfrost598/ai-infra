ENVIRONMENT=development
APP_NAME=Inferix API
APP_VERSION=0.1.0
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000
# Set these in production. Generate INFERIX_SECRET_KEY with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
INFERIX_API_KEY=
INFERIX_SECRET_KEY=
SSH_TRUST_UNKNOWN_HOSTS=false
INFERENCE_PROXY_PUBLIC_BASE_URL=

DATABASE_URL=postgresql+psycopg2://inferix_user:change_me@postgres:5432/inferix

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
REDIS_CACHE_URL=redis://redis:6379/2

CLORE_API_KEY=replace_me
PLAYBOOKS_GIT_REPO=https://github.com/killerfrost598/ansible-playbooks.git
PLAYBOOKS_GIT_BRANCH=main
LOGS_BASE_PATH=/var/log/inferix

# First boot only: values seed platform_settings and never overwrite user edits.
DEFAULT_SEED_MODELS=meta-llama/Llama-3.1-8B-Instruct,Qwen/Qwen2.5-7B-Instruct
DEFAULT_GLOBAL_FILTERS={"pcie_gen":3,"pcie_width":8,"disk_gb":100,"download_mbps":500,"upload_mbps":200}
DEFAULT_EXCLUDED_QUANT_FORMATS=gguf,mlx
