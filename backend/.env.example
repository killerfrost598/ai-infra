ENVIRONMENT=development
APP_NAME=AI Inference Platform API
APP_VERSION=0.1.0
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000

DATABASE_URL=postgresql+psycopg2://ai_user:ai_password@postgres:5432/ai_inference

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

CLORE_API_KEY=
PLAYBOOKS_GIT_REPO=https://github.com/killerfrost598/ansible-playbooks.git
PLAYBOOKS_GIT_BRANCH=main
LOGS_BASE_PATH=/var/log/aip
