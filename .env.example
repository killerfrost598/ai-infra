# ----- Global / Compose -----
PROJECT_NAME=inferix
COMPOSE_PROJECT_NAME=inferix

# ----- Backend -----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000
# Set these in production. Generate INFERIX_SECRET_KEY with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
INFERIX_API_KEY=
INFERIX_SECRET_KEY=
SSH_TRUST_UNKNOWN_HOSTS=false

# ----- Frontend -----
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_INFERIX_API_KEY=

# ----- Database -----
POSTGRES_DB=inferix
POSTGRES_USER=inferix_user
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://inferix_user:change_me@postgres:5432/inferix

# ----- Redis / Celery -----
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
REDIS_CACHE_URL=redis://redis:6379/2

# ----- Provider / Integrations -----
CLORE_API_KEY=replace_me
PLAYBOOKS_GIT_REPO=https://github.com/killerfrost598/ansible-playbooks.git
PLAYBOOKS_GIT_BRANCH=main
