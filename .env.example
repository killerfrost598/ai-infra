# ----- Global / Compose -----
PROJECT_NAME=ai-inference-platform
COMPOSE_PROJECT_NAME=aiinference

# ----- Backend -----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000

# ----- Frontend -----
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ----- Database -----
POSTGRES_DB=ai_inference
POSTGRES_USER=ai_user
POSTGRES_PASSWORD=ai_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://ai_user:ai_password@postgres:5432/ai_inference

# ----- Redis / Celery -----
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ----- Provider / Integrations -----
CLORE_API_KEY=
PLAYBOOKS_GIT_REPO=https://github.com/killerfrost598/ansible-playbooks.git
PLAYBOOKS_GIT_BRANCH=main
